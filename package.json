{
  "name": "novel-extractor",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "desktop:dev": "pnpm --filter @novel-extractor/desktop dev",
    "desktop:build": "pnpm --filter @novel-extractor/desktop build",
    "desktop:dist": "pnpm --filter @novel-extractor/desktop dist",
    "desktop:dist:direct": "pnpm --filter @novel-extractor/desktop dist:direct",
    "desktop:repack": "pnpm --filter @novel-extractor/desktop repack",
    "test:ts": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
